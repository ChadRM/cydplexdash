#pragma once

// Copy this file to secrets.h (gitignored) and fill in your real values.

// WiFi credentials are no longer set here - on first boot (or if none of its saved networks
// are in range) the device opens a "CYD-Setup" WiFi network with a captive-portal page for
// entering credentials, and remembers up to 5 networks it has joined successfully.

// Local IP of your Plex Media Server on your home LAN, e.g. "192.168.1.50" - tried first,
// with a short timeout, so the device is fast when it's actually on your home network.
#define PLEX_LOCAL_IP "192.168.1.50"
#define PLEX_SERVER_PORT 32400
#define PLEX_SERVER_NAME "MyPlexServer"

// Tailscale Funnel hostname for your Plex server (no scheme/port - Funnel is always HTTPS on
// 443), e.g. "myplexhost.tail-scale-name.ts.net". Used as a fallback when PLEX_LOCAL_IP isn't
// reachable (device away from home). Set up with `tailscale funnel --bg 32400` run on the Plex
// host. NOTE: this exposes Plex's HTTP API to the public internet, gated only by PLEX_TOKEN
// below (same as today) - treat this hostname as semi-secret.
#define PLEX_FUNNEL_HOST "myplexhost.example.ts.net"

// Settings > find under "Authorize this device", or see:
// https://support.plex.tv/articles/204059436-finding-an-authentication-token-x-plex-token/
#define PLEX_TOKEN "your-plex-token-here"

// NTP time sync (used for the on-screen clock and night-mode scheduling below)
#define NTP_SERVER "pool.ntp.org"
#define GMT_OFFSET_SEC (-5 * 3600) // your UTC offset in seconds, standard time (e.g. -5*3600 for US Eastern)
#define DAYLIGHT_OFFSET_SEC 3600   // 1 hour DST offset, or 0 if your area doesn't observe DST

// Screen goes dark (screensaver) during these local hours (0-23, wraps past midnight fine),
// and also after 5 minutes of nothing playing.
#define NIGHT_MODE_START_HOUR 22 // 10:00 PM
#define NIGHT_MODE_END_HOUR 8    // 8:00 AM
